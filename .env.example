LINE_CHANNEL_ACCESS_TOKEN=your_line_channel_access_token
LINE_CHANNEL_SECRET=your_line_channel_secret
OPENAI_API_KEY=your_openai_api_key

# Use a current OpenAI model available to your account.
OPENAI_MODEL=gpt-5.2

# Group behavior:
# - Direct 1:1 chats always get a reply.
# - Group/room chats reply when the text starts with BOT_TRIGGER_PREFIX,
#   or when the message mentions LINE_BOT_USER_ID / LINE_BOT_MENTION_NAME.
BOT_TRIGGER_PREFIX=/ask
LINE_BOT_USER_ID=
LINE_BOT_MENTION_NAME=

BOT_SYSTEM_PROMPT=You are a helpful assistant in a LINE group chat. Reply in Traditional Chinese by default unless the user asks for another language.
